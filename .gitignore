# Paid-eval generated artefacts (region/without/with renders + reports).
apps/modal-backend/tests/**/reports/

# Demo render outputs (regenerable; keep the recorders, not the binaries).
# NOTE: the landing-page clip lives at apps/web/public/demo.mp4 (a different dir),
# so these globs never touch it. Everything under scripts/record-demo/ is output.
scripts/record-demo/*.mp4
scripts/record-demo/*.webm
scripts/record-demo/geo-storyboard.png

# Vitest coverage HTML/json output.
apps/web/coverage/

# Perfbudget run output (committed `budgets.json` is the gate; report.json is per-run).
scripts/perfbudget/report.json

# ESLint flat-config cache.
.eslintcache

# Superpowers brainstorm companion (ephemeral mockup files).
.superpowers/

# Ground-truth corpus images (fetched by scripts/fetch_corpus.py; text-only
# descriptions + the sha-pinned manifest are what git tracks).
apps/modal-backend/tests/map_corpus/images/
