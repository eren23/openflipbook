# ------------------------------------------------------------------
# Endless Canvas — BYO keys
# Copy to .env.local inside apps/web and apps/modal-backend as needed.
# ------------------------------------------------------------------

# --- Modal backend ---
FAL_KEY=
OPENROUTER_API_KEY=
# Model overrides (optional). Defaults set in apps/modal-backend/providers/llm.py
OPENROUTER_VLM_MODEL=qwen/qwen-2.5-vl-72b-instruct
OPENROUTER_TEXT_MODEL=qwen/qwen-2.5-72b-instruct
# When true, text calls append ":online" to enable Exa-backed web search.
OPENROUTER_ENABLE_WEB_SEARCH=true

# --- Web (apps/web/.env.local) ---
# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=openflipbook
R2_PUBLIC_BASE_URL=

# MongoDB (Railway Mongo template, Mongo Atlas, or local)
MONGODB_URI=
MONGODB_DB=openflipbook

# Modal URLs — printed after `modal deploy`
MODAL_API_URL=
NEXT_PUBLIC_LTX_WS_URL=
